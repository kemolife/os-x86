C_SOURCES = $(wildcard kernel/*.c drivers/*.c cpu/*.c libc/*.c)
HEADERS = $(wildcard kernel/*.h drivers/*.h cpu/*.h libc/*.h)
# Nice syntax for file extension replacement
OBJ = ${C_SOURCES:.c=.o cpu/interrupt.o} 
BIN = bin/boot bin/kernel

# Docker / Linux (default — works inside the provided Dockerfile)
CC  = gcc
GDB = gdb
LD  = i686-linux-gnu-ld

# macOS native (Homebrew cross-compiler) — uncomment and comment out above:
# CC  = i386-elf-gcc
# GDB = i386-elf-gdb
# LD  = i386-elf-ld
# -g: Use debugging symbols in gcc
CFLAGS = -g -ffreestanding -Wall -Wextra -fno-exceptions -m32 -fno-pie -fno-pic

# First rule is run by default
os-image.bin: boot/bootstrap.bin kernel.bin
	cat boot/bootstrap.bin bin/kernel/kernel.bin > os-image.bin

# '--oformat binary' deletes all symbols as a collateral, so we don't need
# to 'strip' them manually on this case
kernel.bin: boot/kernel_entry.o ${OBJ}
	${LD} -o bin/kernel/$@ -Ttext 0x1000 $^ --oformat binary

# Used for debugging purposes
kernel.elf: boot/kernel_entry.o ${OBJ}
	${LD} -o bin/kernel/$@ -Ttext 0x1000 $^

run: os-image.bin
	qemu-system-i386 -drive file=os-image.bin,format=raw,if=floppy -curses

# Open the connection to qemu and load our kernel-object file with symbols
debug: os-image.bin kernel.elf
	qemu-system-i386 -s -fda os-image.bin &
	${GDB} -ex "target remote localhost:1234" -ex "symbol-file kernel.elf"

# Generic rules for wildcards
# To make an object, always compile from its .c
%.o: %.c ${HEADERS}
	${CC} ${CFLAGS} -ffreestanding -c $< -o $@

%.o: %.asm | dir
	nasm $< -f elf -o $@

%.bin: %.asm | dir
	nasm $< -f bin -o $@

dir:
	mkdir -p $(BIN)

clean:
	rm -rf bin os-image.bin
	rm -f boot/*.bin boot/*.o kernel/*.o drivers/*.o cpu/*.o libc/*.o